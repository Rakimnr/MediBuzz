<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".MediBuzzApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MediBuzz">

        <!-- Welcome screen -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Authentication and role flow -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />
        <activity
            android:name=".RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".ChooseRoleActivity"
            android:exported="false" />
        <activity
            android:name=".PartnerConnectActivity"
            android:exported="false" />

        <!-- Main app screens -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".AddMedicineActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".SharingSettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />
        <activity
            android:name=".PartnerDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <!-- Alarm receiver: fires reminders -->
        <receiver
            android:name=".ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.medibuzz.ACTION_REMINDER" />
                <action android:name="com.medibuzz.ACTION_REPEAT_REMINDER" />
            </intent-filter>
        </receiver>

        <!-- Notification action receiver: Taken, Snooze, Skipped -->
        <receiver
            android:name=".NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.medibuzz.ACTION_TAKEN" />
                <action android:name="com.medibuzz.ACTION_SNOOZE" />
                <action android:name="com.medibuzz.ACTION_SKIPPED" />
            </intent-filter>
        </receiver>

        <!-- Reschedule alarms after reboot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
